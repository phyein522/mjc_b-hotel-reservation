<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mjc.hotel.user.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.mjc.hotel.user.entity.User">
        <id property="userId" column="user_id"/>
        <result property="email" column="email"/>
        <result property="password" column="password"/>
        <result property="name" column="name"/>
        <result property="phone" column="phone"/>
        <result property="role" column="role"
                javaType="com.mjc.hotel.user.entity.Role"/>
        <result property="status" column="status"
                javaType="com.mjc.hotel.user.entity.Status"/>
        <result property="membership" column="membership"
                javaType="com.mjc.hotel.user.entity.Membership"/>
        <result property="createdAt" column="created_at"/>
        <result property="modifiedAt" column="modified_at"/>
    </resultMap>

    <select id="getUsers" resultMap="UserResultMap">
        SELECT user_id, email, password, name, phone, role, status, membership,
               created_at, modified_at
        FROM users
    </select>

    <select id="getUserById" parameterType="long" resultMap="UserResultMap">
        SELECT user_id, email, password, name, phone, role, status, membership,
               created_at, modified_at
        FROM users
        WHERE user_id = #{userId}
    </select>

    <insert id="insertUser" parameterType="com.mjc.hotel.user.entity.User"
            useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO users (email, password, name, phone, role, status, membership,
                           created_at, modified_at)
        VALUES (#{email}, #{password}, #{name}, #{phone}, #{role}, #{status}, #{membership},
                NOW(), NOW())
    </insert>

    <update id="updateUser" parameterType="com.mjc.hotel.user.entity.User">
        UPDATE users
        SET email = #{email},
            password = #{password},
            name = #{name},
            phone = #{phone},
            role = #{role},
            status = #{status},
            membership = #{membership},
            modified_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <delete id="deleteUser" parameterType="long">
        DELETE FROM users WHERE user_id = #{userId}
    </delete>

</mapper>